#!/bin/bash
#
# Sample pre-commit hook for local safety checks.
# Copy to .git/hooks/pre-commit or run: ln -s ../../hooks/pre-commit.sample .git/hooks/pre-commit
#
# Blocks commits on the main branch when a local commander prompt file exists.

set -euo pipefail

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"

if [[ "$branch" == "main" && -f ".commander-prompt.txt" ]]; then
  echo "pre-commit: refusing to commit on main while .commander-prompt.txt exists." >&2
  echo "Remove .commander-prompt.txt or switch to a feature branch before committing." >&2
  exit 1
fi
