{
  "version": 1,
  "pack_id": "winsmux-cli-bakeoff-v1",
  "title": "winsmux Harness Bench worker-pane benchmark",
  "methodology_reference": "https://nyosegawa.com/posts/harness-bench/",
  "minimum_task_count_for_directional_findings": 27,
  "official_task_count_target": 27,
  "review_model": "gpt-5.5",
  "review_policy": {
    "primary_scoring": "deterministic_checks",
    "llm_review_role": "failure_audit_and_quality_control",
    "candidate_self_report_counts_for_scoring": false,
    "same_family_review_counts_for_scoring": false
  },
  "scoring": {
    "axes": {
      "accuracy": 30,
      "review_findings": 20,
      "speed": 15,
      "parallelism": 15,
      "async_terminal": 10,
      "evidence_quality": 10
    },
    "caps": [
      {
        "condition": "tests_do_not_start_or_primary_feature_unusable",
        "max_score": 40
      },
      {
        "condition": "any_p0_finding",
        "max_score": 50
      },
      {
        "condition": "two_or_more_p1_findings",
        "max_score": 70
      },
      {
        "condition": "missing_reproducible_evidence",
        "max_score": 60
      }
    ],
    "review_score_formula": "max(0, 100 - P0*45 - P1*20 - P2*6 - P3*2)"
  },
  "qc_gates": [
    "same_task_packet_sha256_for_all_workers",
    "same_timeout_for_all_workers",
    "same_workspace_for_all_workers",
    "preflight_all_pass_before_recording",
    "desktop_app_screen_recording_required",
    "visible_worker_pane_required_for_every_scored_worker",
    "operator_intervention_zero_required",
    "worker_to_worker_messaging_disabled",
    "run_governance_fields_required",
    "non_completed_worker_results_excluded_from_scoring",
    "antigravity_empty_stdout_excluded_from_machine_scoring",
    "harness_bench_27_tasks_required",
    "hidden_tests_required",
    "sanitized_workspace_required",
    "operator_rows_excluded_from_scoring",
    "missing_key_timeout_crash_empty_stdout_invalid_output_excluded_from_scoring"
  ],
  "default_timeout_seconds": 3600,
  "run_governance": {
    "same_task_set_for_all_workers": true,
    "same_timeout_for_all_workers": true,
    "same_workspace_for_all_workers": true,
    "operator_intervention_limit": 0,
    "worker_to_worker_messaging": "disabled",
    "execution_surface": "visible_desktop_worker_panes",
    "required_run_fields": [
      "messaging_state",
      "operator_intervention_count",
      "execution_surface"
    ]
  },
  "default_workers": [
    {
      "pane": "worker-1",
      "role": "harness-bench-worker",
      "cli": "Claude Code",
      "model": "claude-opus-4-8",
      "effort": "xhigh",
      "display_model": "Claude Code / Claude Opus 4.8",
      "auth_mode": "claude-code-local",
      "scored": true
    },
    {
      "pane": "worker-2",
      "role": "harness-bench-worker",
      "cli": "Codex",
      "model": "gpt-5.5",
      "effort": "xhigh",
      "display_model": "Codex / gpt-5.5",
      "auth_mode": "codex-local",
      "scored": true
    },
    {
      "pane": "worker-3",
      "role": "harness-bench-worker",
      "cli": "Antigravity CLI",
      "worker_backend": "antigravity",
      "agent": "antigravity",
      "model": "Gemini 3.5 Flash (High)",
