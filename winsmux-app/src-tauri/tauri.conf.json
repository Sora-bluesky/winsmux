{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "winsmux",
  "version": "0.36.24",
  "identifier": "io.github.sora-bluesky.winsmux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "winsmux",
        "width": 800,
        "height": 600,
        "visible": false,
        "backgroundColor": "#0b0f14"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://openrouter.ai; frame-src http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": {
          "en-US": {
            "localePath": "wix-en-US.wxl"
          },
          "ja-JP": {
            "localePath": "wix-ja-JP.wxl"
          }
        },
        "fragmentPaths": [
          "wix-explorer-context-menu.wxs"
        ],
        "componentRefs": [
          "ExplorerFolderContextMenu",
          "ExplorerFolderBackgroundContextMenu"
        ]
      },
      "nsis": {
        "installerHooks": "nsis-installer-hooks.nsh",
        "languages": [
          "English",
          "Japanese"
        ],
        "displayLanguageSelector": true
      }
    }
  }
}
