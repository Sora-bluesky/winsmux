{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-session-start.js"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-session-end.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-gate.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-injection-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-channel-detect.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-quiet-inject.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-data-boundary.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-issue-gate.js"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-injection-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-data-boundary.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-invisible-char-scan.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-injection-guard.js"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-orchestra-gate.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-permission.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-evidence.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-output-control.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-pane-monitor.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/lint-on-save.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-dep-audit.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-user-prompt.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-circuit-breaker.js"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-subagent.js"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-worktree.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-precompact.js"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-postcompact.js"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-elicitation.js"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-config-guard.js"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-instructions.js"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-permission-learn.js"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sh-pipeline.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/sh-task-gate.js"
          }
        ]
      }
    ]
  }
}








